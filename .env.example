# Supabase 接続情報（レッスン機能・作品の保存・管理画面 /admin で使用）
# Supabase ダッシュボード → Project Settings → API から取得し、
# このファイルを .env にコピーして値を埋める。
# 未設定の場合、レッスンは取得できず一覧が空になり（レッスンの正データは Supabase）、
# ログイン・作品の保存もできない（ヘッダーにログイン導線が出ない）。
#
# 注意: anon キーは公開前提のキー。レッスンは anon からは読み取りのみで、書き込みは Edge Function
# （service_role）＋独自の管理者認証で保護する。学習者の作品は Supabase Auth のセッションと
# RLS（本人の行だけ）で保護する（supabase/migrations/・supabase/functions/ 参照）。
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 任意: 本番マイグレーション適用（npm run db:push）の取り違え防止用。
# 本番プロジェクトの ref を入れておくと、リンク先がこれと一致しない時は push を中止する。
SUPABASE_PROD_REF=

# ローカルの Google ログイン（学習者アカウント）用。`npx supabase start` が
# supabase/config.toml の env(...) 経由で読む。Google Cloud の OAuth クライアントから取得する。
# 本番はここではなく Supabase ダッシュボード（Authentication → Providers → Google）に設定する。
# 未設定でもローカルスタックは起動するが、Google ログインは失敗する。
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
