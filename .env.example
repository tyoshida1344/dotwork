# Supabase 接続情報（レッスン管理画面 /admin で使用）
# Supabase ダッシュボード → Project Settings → API から取得し、
# このファイルを .env にコピーして値を埋める。
# どちらも未設定の場合、レッスンはバンドルの lessons.json から読み込まれる（フォールバック）。
#
# 注意: anon キーは公開前提のキー。書き込みは RLS と Supabase Auth で保護する（supabase/migrations/ 参照）。
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 任意: 本番マイグレーション適用（npm run db:push）の取り違え防止用。
# 本番プロジェクトの ref を入れておくと、リンク先がこれと一致しない時は push を中止する。
SUPABASE_PROD_REF=
